{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "make",
      "runtimeArgs": [
        "dev-api"
      ],
      "port": 8765
    },
    {
      "name": "web",
      "runtimeExecutable": "make",
      "runtimeArgs": [
        "dev-web"
      ],
      "port": 5173
    },
    {
      "name": "web-alt",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd web && npx vite --host 0.0.0.0 --port 5199"
      ],
      "port": 5199
    },
    {
      "name": "web-preview",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd web && bun run build && bun run preview"
      ],
      "port": 4173
    }
  ]
}