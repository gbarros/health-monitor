FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src

WORKDIR /app

COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir \
    "fastapi>=0.116" \
    "pydantic>=2.11" \
    "pydantic-ai>=0.7" \
    "sqlalchemy>=2.0" \
    "alembic>=1.16" \
    "psycopg[binary]>=3.2" \
    "uvicorn[standard]>=0.35"
COPY src ./src

EXPOSE 8765

CMD ["python", "-m", "health_monitor", "api", "--host", "0.0.0.0", "--port", "8765"]
